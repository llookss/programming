#include <iostream>
enum studentsName
{
    kim, //0
    lee, //1
    park, //2
    numOfStudents //3
};

void printStudentName(const studentsName name)
{
    switch(name)
    {
    case kim:
        std::cout << "KIM,"; 
        break;
    case lee:
        std::cout << "LEE,"; 
        break;
    case park: 
        std::cout << "PARK,"; 
        break;
    default:
        std::cout << "NO NAME,";
    }
}


struct student
{
    studentsName name{ kim };
    int id{ 2630005 };
    int score{ 0 };
    char grade{ 'F' };

};

void score2grade(const int&score, char&grade)
{
    if (score >= 90) grade = 'A';
    else if (score >=80) grade = 'B';
    else if (score >=70) grade = 'C';
    else if (score >=60) grade = 'D';
    else grade = 'F';
}
void inputStudent(student& s)
{ 
    s.name = static_cast<studentsName> (rand() % numOfStudents); //rand() 0~RANSD_MAX int, name: 0~2%
    std::cout << "Enter id: ";
        std::cin >> s. id;
    std::cout<< "Enter score: ";
        std::cin >> s. score;
    score2grade(s.score, s.grade);
}

void printStudent(const student& s)

{
    printStudentName(s. name);
    std::cout << s. id << ":" << s.score << "(" << s.grade << ")\n";
}


int main()

{
    student s1;
    inputStudent(s1);
    printStudent(s1);




    return 0;
}
